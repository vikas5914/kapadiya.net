---
import "@styles/global.css";
import Header from "@components/Header";
import Footer from "@components/Footer.astro";
import BaseHead from "../components/BaseHead.astro";
import { metaData } from "../config";

export interface Props {
  title: string;
  description: string;
  author?: string;
  date: string | Date;
  readTime: string;
  category: string;
  featured?: boolean;
  slug: string;
  cover?: string;
  excerpt?: string;
}

const {
  title,
  description,
  author = metaData.name,
  date,
  readTime,
  category,
  featured = false,
  cover,
} = Astro.props;

const dateObj = new Date(date);
const formattedDate = new Intl.DateTimeFormat("en-US", {
  dateStyle: "long",
}).format(dateObj);
const isoDate = dateObj.toISOString().slice(0, 10);
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="googlebot"
      content="index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <BaseHead title={title} description={description} image={cover} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={metaData.title}
      href={new URL("rss.xml", Astro.site)}
    />
  </head>
  <body class="antialiased">
    <div class="min-h-screen">
      <Header client:load />
      <main class="pt-16">
        <article class="py-18">
          <div class="mx-auto max-w-[800px] px-6 sm:px-12">
            <!-- Back to Blog -->
            <div class="mb-8">
              <a
                href="/blog"
                class="inline-flex items-center gap-2 no-underline text-[11px] font-medium tracking-[0.1em] uppercase text-ind-accent border border-ind-accent px-4 py-2 transition-colors duration-[240ms] hover:bg-ind-accent hover:text-text-on-accent"
              >
                ← Back to Blog
              </a>
            </div>

            <!-- Article Header -->
            <header class="mb-12 pb-8 border-b border-border-soft">
              <div class="flex items-center gap-3 mb-5">
                <span class="text-[11px] font-semibold tracking-[0.12em] uppercase text-text-on-accent bg-ind-accent px-3 py-1.5">
                  {category}
                </span>
                {featured && (
                  <span class="text-[11px] font-bold tracking-[0.12em] uppercase text-ind-accent bg-bg-main border border-ind-accent px-2.5 py-1">
                    Featured
                  </span>
                )}
              </div>

              <h1 class="text-[clamp(28px,4vw,40px)] font-bold tracking-[-0.04em] text-text-primary leading-[1.1] mb-5">
                {title}
              </h1>

              <div class="flex flex-wrap items-center gap-6 mb-5">
                <span class="text-[13px] text-text-secondary tracking-[-0.02em]">
                  {author}
                </span>
                <time datetime={isoDate} class="text-[13px] text-text-secondary tracking-[-0.02em]">
                  {formattedDate}
                </time>
                <span class="text-[13px] text-text-secondary tracking-[-0.02em]">
                  {readTime}
                </span>
              </div>

              <p class="text-[17px] leading-[1.7] text-text-secondary max-w-[640px]">
                {description}
              </p>
            </header>

            <!-- Article Content -->
            <div class="prose prose-lg max-w-none blog-prose">
              <slot />
            </div>

            <!-- CTA -->
            <div class="bg-surface p-7 mt-12 border border-border-soft">
              <div class="text-[16px] font-bold text-text-primary mb-2">
                What's Next?
              </div>
              <p class="text-[13px] leading-[1.65] text-text-secondary mb-4">
                Want to dive deeper into web development? Check out my other
                posts on building scalable applications and modern development
                practices.
              </p>
              <a
                href="/blog"
                class="inline-block no-underline text-[12px] font-semibold tracking-[0.1em] uppercase bg-ind-accent text-text-on-accent px-6 py-3 transition-opacity duration-[240ms] hover:opacity-90"
              >
                View All Posts →
              </a>
            </div>
          </div>
        </article>
      </main>
      <Footer />
    </div>
  </body>
</html>

<style>
  /* Prose styles target slot-rendered MDX content via :global(); cannot use Tailwind utilities here. */
  .blog-prose {
    color: var(--text-secondary);
    font-size: 16px;
    line-height: 1.75;
  }
  .blog-prose :global(h1),
  .blog-prose :global(h2),
  .blog-prose :global(h3),
  .blog-prose :global(h4) {
    color: var(--text-primary);
    font-weight: 700;
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }
  .blog-prose :global(h2) {
    font-size: 24px;
    margin-top: 48px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-soft);
  }
  .blog-prose :global(h3) {
    font-size: 18px;
    margin-top: 32px;
    margin-bottom: 12px;
  }
  .blog-prose :global(p) {
    margin-bottom: 20px;
  }
  .blog-prose :global(a) {
    color: var(--ind-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .blog-prose :global(a:hover) {
    color: var(--ind-accent-hover);
  }
  .blog-prose :global(pre) {
    background: var(--surface) !important;
    border: 1px solid var(--border-medium);
    padding: 20px;
    margin: 24px 0;
    overflow-x: auto;
    font-size: 13px;
  }
  .blog-prose :global(blockquote) {
    border-left: 3px solid var(--ind-accent);
    padding-left: 20px;
    color: var(--text-secondary);
    font-style: italic;
    margin: 24px 0;
  }
  .blog-prose :global(ul),
  .blog-prose :global(ol) {
    padding-left: 20px;
    margin-bottom: 20px;
  }
  .blog-prose :global(li) {
    color: var(--text-secondary);
    font-size: 16px;
    line-height: 1.75;
    margin-bottom: 8px;
  }
  .blog-prose :global(img) {
    max-width: 100%;
    margin: 24px 0;
  }
  .blog-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border-medium);
    margin: 32px 0;
  }
  .blog-prose :global(table) {
    width: 100%;
    border: 1px solid var(--border-strong);
    border-collapse: collapse;
    margin: 24px 0;
  }
  .blog-prose :global(th),
  .blog-prose :global(td) {
    border: 1px solid var(--border-strong);
    padding: 10px 14px;
    font-size: 13px;
  }
  .blog-prose :global(th) {
    background: var(--surface);
    color: var(--text-primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 11px;
  }
</style>
