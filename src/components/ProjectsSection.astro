---
import { projects } from "../config";
import { socialLinks } from "../config";

const [featured, ...rest] = projects;
---

<section id="projects" class="border-b border-border-medium">
  <div class="mx-auto max-w-[1440px] px-6 sm:px-12">
    <div class="border-x border-border-strong">
      <header class="ledger-grid grid border-b border-border-strong">
        <div class="px-6 py-14 sm:px-10 sm:py-18 lg:px-14">
          <p class="mb-5 max-w-[58ch] text-sm leading-relaxed text-text-secondary">
            Open-source tools built to solve real annoyances. Stars are useful;
            the stronger proof is that the software is still doing the job.
          </p>
          <h2 class="section-title font-bold uppercase text-text-primary">
            Work, not claims.
          </h2>
        </div>
        <div class="flex flex-col justify-between border-t border-border-strong bg-surface p-6 sm:p-8 lg:border-t-0 lg:border-l">
          <span class="font-mono text-xs font-medium tracking-[0.12em] text-ind-accent uppercase">
            Open source
          </span>
          <div class="mt-10">
            <div class="text-2xl font-semibold tracking-tight text-text-primary">704 stars</div>
            <div class="mt-1 text-sm text-text-muted">across 93 public repositories</div>
          </div>
          <a
            href={socialLinks.github}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-8 flex min-h-11 items-center justify-between border-t border-border-medium pt-4 font-mono text-xs font-medium tracking-[0.12em] text-ind-accent uppercase no-underline transition-colors duration-[240ms] hover:text-ind-accent-hover focus-visible:outline-2 focus-visible:outline-ind-accent focus-visible:outline-offset-2"
          >
            All repositories <span aria-hidden="true">↗</span>
          </a>
        </div>
      </header>

      <a
        href={featured.url}
        target="_blank"
        rel="noopener noreferrer"
        class="ledger-grid group grid border-b border-border-strong text-text-primary no-underline transition-colors duration-[240ms] hover:bg-surface focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-ind-accent"
      >
        <div class="px-6 py-12 sm:px-10 lg:px-14 lg:py-16">
          <div class="mb-7 flex flex-wrap items-center gap-3 font-mono text-xs font-medium tracking-[0.12em] uppercase">
            <span class="bg-ind-accent px-2.5 py-1.5 text-text-on-accent">Most starred</span>
            <span class="text-text-muted">JavaScript · Playwright</span>
          </div>
          <h3 class="project-name max-w-[16ch] font-bold tracking-tight text-text-primary transition-colors duration-[240ms] group-hover:text-ind-accent">
            {featured.name}
          </h3>
          <p class="mt-5 max-w-[55ch] text-base leading-relaxed text-text-secondary">
            {featured.description}
          </p>
        </div>
        <div class="flex flex-col justify-between border-t border-border-strong p-6 sm:p-8 lg:border-t-0 lg:border-l">
          <div class="grid grid-cols-2 gap-px bg-border-strong">
            <div class="bg-bg-main p-4">
              <div class="font-mono text-xs tracking-[0.12em] text-text-muted uppercase">Stars</div>
              <div class="mt-2 text-2xl font-semibold tabular-nums text-text-primary">{featured.stars}</div>
            </div>
            <div class="bg-bg-main p-4">
              <div class="font-mono text-xs tracking-[0.12em] text-text-muted uppercase">Proof</div>
              <div class="mt-2 text-sm font-semibold text-text-primary">{featured.proof}</div>
            </div>
          </div>
          <div class="mt-10 flex items-end justify-between">
            <div class="flex flex-wrap gap-2">
              {featured.tags.map((tag) => (
                <span class="border border-border-medium px-2.5 py-1 font-mono text-xs tracking-[0.08em] text-text-secondary uppercase">
                  {tag}
                </span>
              ))}
            </div>
            <span class="ml-5 text-2xl text-ind-accent transition-transform duration-[240ms] group-hover:translate-x-1" aria-hidden="true">↗</span>
          </div>
        </div>
      </a>

      <div>
        {rest.map((project, index) => (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              "group grid grid-cols-1 px-6 py-8 text-text-primary no-underline transition-colors duration-[240ms] hover:bg-surface focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-ind-accent sm:px-10 lg:grid-cols-[minmax(220px,0.7fr)_minmax(0,1.3fr)_180px_40px] lg:items-center lg:px-14",
              index < rest.length - 1 && "border-b border-border-strong",
            ]}
          >
            <h3 class="text-xl font-semibold tracking-tight text-text-primary transition-colors duration-[240ms] group-hover:text-ind-accent">
              {project.name}
            </h3>
            <p class="mt-3 max-w-[58ch] text-sm leading-relaxed text-text-muted lg:mt-0 lg:px-8">
              {project.description}
            </p>
            <div class="mt-5 flex items-center gap-3 font-mono text-xs tracking-[0.08em] uppercase lg:mt-0">
              <span class="text-text-primary">★ {project.stars}</span>
              <span class="text-text-muted">{project.proof}</span>
            </div>
            <span class="mt-5 text-xl text-ind-accent transition-transform duration-[240ms] group-hover:translate-x-1 lg:mt-0 lg:text-right" aria-hidden="true">↗</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
