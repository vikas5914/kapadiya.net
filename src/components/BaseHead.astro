---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  pageType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  section?: string;
  tags?: string[];
}

import { metaData } from "../config";
import { SEO } from "astro-seo";

let {
  title,
  description = metaData.description,
  image,
  pageType = "website",
  publishedTime,
  modifiedTime,
  section,
  tags = [],
} = Astro.props;

const { url, site } = Astro;

import { getImagePath } from "astro-takumi";

const openGraphImageUrl = image ?? getImagePath({ url, site });

if (title && title !== metaData.title) {
  title = `${title} | ${metaData.name}`;
}
---

<SEO
  title={title}
  titleDefault={metaData.title}
  description={description}
  openGraph={{
    basic: {
      title: title || metaData.title,
      type: pageType,
      image: openGraphImageUrl,
      url: url,
    },
    optional: {
      description,
      siteName: metaData.name,
      locale: "en_US",
    },
    image: {
      width: 1200,
      height: 630,
      alt: `${title || metaData.title} social preview`,
    },
    article: pageType === "article" ? {
      publishedTime,
      modifiedTime,
      authors: [metaData.baseUrl],
      section,
      tags,
    } : undefined,
  }}
  twitter={{
    card: "summary_large_image",
    title: title || metaData.title,
    description,
    image: openGraphImageUrl,
    imageAlt: `${title || metaData.title} social preview`,
    site: "@kapadiyavikas",
    creator: "@kapadiyavikas",
  }}
  extend={{
    link: [
      { rel: "icon", type: "image/svg+xml", href: "/favicon.svg" },
      { rel: "icon", type: "image/png", sizes: "32x32", href: "/favicon-32x32.png" },
      { rel: "apple-touch-icon", sizes: "180x180", href: "/apple-touch-icon.png" },
      { rel: "manifest", href: "/site.webmanifest" },
    ],
    meta: [
      {
        property: "og:logo",
        content: new URL("/favicon.png", metaData.baseUrl).href,
      },
    ],
  }}
/>
