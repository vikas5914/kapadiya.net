---
import { skillGroups, socialLinks } from "../config";

const operatingNotes = [
  {
    label: "Now",
    copy: "AI engineer at Shopos AI, working on agents, LLM APIs, and the services behind them.",
  },
  {
    label: "Before",
    copy: "A decade of full-stack web work: PHP and Laravel first, then Node, React, databases, and AWS.",
  },
  {
    label: "Always",
    copy: "Open source when a problem keeps itching; writing when the solution is worth explaining twice.",
  },
];

const socials = [
  { label: "GitHub", value: "@vikas5914", href: socialLinks.github },
  { label: "X", value: "@kapadiyavikas", href: socialLinks.twitter },
  { label: "Bluesky", value: "kapadiya.net", href: socialLinks.bluesky },
  { label: "LinkedIn", value: "vikaskapadiya", href: socialLinks.linkedin },
];
---

<section id="about" class="border-b border-border-medium">
  <div class="mx-auto max-w-[1440px] px-6 sm:px-12">
    <div class="profile-grid grid border-x border-border-strong">
      <div class="flex min-h-[520px] flex-col justify-between bg-ind-accent p-6 text-text-on-accent sm:p-10 lg:p-14">
        <div class="flex items-center justify-between border-b border-black/30 pb-4 font-mono text-xs font-medium tracking-[0.12em] uppercase">
          <span>Working profile</span>
          <span>Est. 2013</span>
        </div>
        <blockquote class="my-14 max-w-[16ch] text-3xl font-bold leading-[1.08] tracking-[-0.03em] sm:text-5xl">
          The stack changes. The habit stays: get useful things into production.
        </blockquote>
        <div class="flex items-end justify-between border-t border-black/30 pt-5">
          <div>
            <div class="text-sm font-semibold">Vikas Kapadiya</div>
            <div class="mt-1 font-mono text-xs tracking-[0.1em] uppercase">AI engineer</div>
          </div>
          <span class="font-mono text-xs tracking-[0.1em] uppercase">10+ years</span>
        </div>
      </div>

      <div>
        <header class="border-b border-border-strong px-6 py-12 sm:px-10 lg:px-14">
          <h2 class="section-title font-bold uppercase text-text-primary">Built across the stack.</h2>
          <p class="mt-5 max-w-[62ch] text-base leading-relaxed text-text-secondary">
            I care about the whole path from an idea to a boring, reliable deploy.
            That usually means product decisions, backend plumbing, frontend details,
            and the odd infrastructure fire in the same week.
          </p>
        </header>

        <div class="divide-y divide-border-strong">
          {operatingNotes.map((note) => (
            <div class="grid grid-cols-1 px-6 py-7 sm:grid-cols-[120px_1fr] sm:px-10 lg:px-14">
              <div class="font-mono text-xs font-medium tracking-[0.12em] text-ind-accent uppercase">
                {note.label}
              </div>
              <p class="mt-3 max-w-[60ch] text-sm leading-relaxed text-text-secondary sm:mt-0">
                {note.copy}
              </p>
            </div>
          ))}
        </div>

        <div class="border-t border-border-strong bg-surface px-6 py-8 sm:px-10 lg:px-14">
          <div class="mb-5 font-mono text-xs font-medium tracking-[0.12em] text-text-muted uppercase">
            Working set
          </div>
          <div class="flex flex-wrap gap-2">
            {skillGroups.flatMap((group) => group.items).map((item) => (
              <span class="border border-border-medium bg-bg-main px-3 py-1.5 font-mono text-xs tracking-[0.08em] text-text-secondary uppercase">
                {item}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="profile-grid grid border-x border-b border-border-strong">
      <div class="border-b border-border-strong px-6 py-10 sm:px-10 lg:border-r lg:border-b-0 lg:px-14">
        <div class="font-mono text-xs font-medium tracking-[0.12em] text-ind-accent uppercase">Direct line</div>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-text-primary">Have a hard problem?</h3>
        <p class="mt-3 max-w-[48ch] text-sm leading-relaxed text-text-secondary">
          Agents, tooling, TypeScript, or something adjacent. Email is the best way to reach me.
        </p>
        <a
          href="mailto:vikas@kapadiya.net"
          class="mt-4 inline-flex min-h-11 max-w-full flex-wrap items-center gap-2 break-all border-b border-ind-accent font-mono text-xs font-semibold tracking-[0.12em] text-ind-accent uppercase no-underline transition-colors duration-[240ms] hover:text-ind-accent-hover focus-visible:outline-2 focus-visible:outline-ind-accent focus-visible:outline-offset-2"
        >
          vikas@kapadiya.net <span aria-hidden="true">↗</span>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2">
        {socials.map((social, index) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              "group flex min-h-28 flex-col justify-between p-5 text-text-primary no-underline transition-colors duration-[240ms] hover:bg-surface focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-ind-accent sm:p-6",
              index < socials.length - 1 && "border-b border-border-strong",
              index >= 2 && "sm:border-b-0",
              index % 2 === 0 && "sm:border-r sm:border-border-strong",
            ]}
          >
            <span class="font-mono text-xs tracking-[0.12em] text-text-muted uppercase">{social.label}</span>
            <span class="flex items-center justify-between text-sm font-semibold">
              {social.value}
              <span class="text-ind-accent transition-transform duration-[240ms] group-hover:translate-x-1" aria-hidden="true">↗</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
