---
import { socialLinks } from "../config";

const socials = [
  { label: "GitHub", value: "@vikas5914", href: socialLinks.github },
  { label: "LinkedIn", value: "vikaskapadiya", href: socialLinks.linkedin },
  { label: "Twitter / X", value: "@kapadiyavikas", href: socialLinks.twitter },
  { label: "Bluesky", value: "kapadiya.net", href: socialLinks.bluesky },
  { label: "Instagram", value: "@kapadiyavikas", href: socialLinks.instagram },
  { label: "Email", value: "vikas@kapadiya.net", href: socialLinks.email },
];
---

<section
  id="about"
  style="padding-top: 72px; padding-bottom: 72px; border-top: 1px solid var(--border-medium);"
>
  <div class="mx-auto" style="max-width: var(--container-max); padding: 0 48px;">
    <!-- Section Header -->
    <div
      class="flex justify-between items-end"
      style="margin-bottom: 48px; padding-bottom: 24px; border-bottom: 1px solid var(--border-soft);"
    >
      <div>
        <div
          style="font-family: 'MonoLisa', monospace; font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ind-accent); margin-bottom: 12px;"
        >
          Background
        </div>
        <h2
          style="font-family: 'MonoLisa', monospace; font-size: 40px; font-weight: 700; letter-spacing: -0.04em; text-transform: uppercase; color: var(--text-primary); line-height: 0.95;"
        >
          About Me
        </h2>
      </div>
      <div
        class="hidden md:block"
        style="font-family: 'MonoLisa', monospace; font-size: 13px; color: var(--text-muted); letter-spacing: -0.02em; max-width: 380px; line-height: 1.6; text-align: right;"
      >
        Passionate full-stack developer with over 8 years of experience crafting digital solutions.
      </div>
    </div>

    <!-- Two Column Grid -->
    <div class="about-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 48px;">
      <!-- Left Column — About Text -->
      <div class="flex flex-col gap-6">
        <p
          style="font-family: 'MonoLisa', monospace; font-size: 14px; line-height: 1.7; letter-spacing: -0.02em; word-spacing: -0.08em; color: var(--text-secondary);"
        >
          I'm a passionate full-stack developer with over 8 years of experience crafting
          digital solutions. My journey started with PHP, and I've been riding the Laravel
          wave since version 5.
        </p>
        <p
          style="font-family: 'MonoLisa', monospace; font-size: 14px; line-height: 1.7; letter-spacing: -0.02em; word-spacing: -0.08em; color: var(--text-secondary);"
        >
          When I'm not debugging code or exploring new frameworks, you'll find me contributing
          to open-source projects or helping fellow developers on Laravel Artisan community.
          I believe in writing clean, maintainable code and sharing knowledge with the
          developer community.
        </p>
        <p
          style="font-family: 'MonoLisa', monospace; font-size: 14px; line-height: 1.7; letter-spacing: -0.02em; word-spacing: -0.08em; color: var(--text-secondary);"
        >
          Currently, I'm exploring the intersection of AI and web development, experimenting
          with tools that can enhance developer productivity while maintaining code quality.
        </p>

        <!-- CTA Block -->
        <div
          style="background: var(--surface); padding: 28px; margin-top: 8px; box-shadow: var(--shadow-sm);"
        >
          <div
            style="font-family: 'MonoLisa', monospace; font-size: 12px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ind-accent); margin-bottom: 8px;"
          >
            Available for freelance work
          </div>
          <div
            style="font-family: 'MonoLisa', monospace; font-size: 13px; line-height: 1.65; letter-spacing: -0.02em; color: var(--text-secondary); margin-bottom: 20px;"
          >
            Let's build something amazing together!
          </div>
          <a
            href="mailto:vikas@kapadiya.net"
            class="inline-flex items-center gap-2 no-underline cta-link"
            style="font-family: 'MonoLisa', monospace; font-size: 11px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; background: var(--ind-accent); color: #fff; border: none; padding: 12px 24px; transition: opacity 240ms ease;"
          >
            Get in touch →
          </a>
        </div>
      </div>

      <!-- Right Column — Social Grid -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; border: 1px solid var(--border-strong);">
        {socials.map((s, i) => {
          const isRight = i % 2 === 1;
          const isLastRow = i >= socials.length - 2;
          return (
            <a
              href={s.href}
              target={s.href.startsWith("mailto") ? undefined : "_blank"}
              rel="noopener noreferrer"
              class="social-item block no-underline"
              style={`padding: 20px; transition: background 240ms ease;${!isRight ? ' border-right: 1px solid var(--border-strong);' : ''}${!isLastRow ? ' border-bottom: 1px solid var(--border-strong);' : ''}`}
            >
              <div
                style="font-family: 'MonoLisa', monospace; font-size: 10px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px;"
              >
                {s.label}
              </div>
              <div
                style="font-family: 'MonoLisa', monospace; font-size: 14px; font-weight: 600; letter-spacing: -0.02em; color: var(--text-primary);"
              >
                {s.value}
              </div>
              <div
                style="font-family: 'MonoLisa', monospace; font-size: 14px; color: var(--ind-accent); margin-top: 8px;"
              >
                →
              </div>
            </a>
          );
        })}

        <!-- Community Block -->
        <div
          class="flex justify-between items-center"
          style="grid-column: 1 / -1; padding: 24px; border-top: 1px solid var(--border-strong);"
        >
          <div>
            <div
              style="font-family: 'MonoLisa', monospace; font-size: 10px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 6px;"
            >
              Community
            </div>
            <div
              style="font-family: 'MonoLisa', monospace; font-size: 16px; font-weight: 700; letter-spacing: -0.04em; text-transform: uppercase; color: var(--text-primary);"
            >
              Laravel Artisan
            </div>
          </div>
          <a
            href="https://telegram.me/LaravelArtisans"
            target="_blank"
            rel="noopener noreferrer"
            class="community-link no-underline"
            style="font-family: 'MonoLisa', monospace; font-size: 11px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ind-accent); border: 1px solid var(--ind-accent); padding: 10px 20px; background: transparent; transition: background 240ms ease, color 240ms ease;"
          >
            Join →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .social-item:hover {
    background: var(--surface) !important;
  }
  .social-item:focus-visible {
    outline: 2px solid var(--ind-accent);
    outline-offset: -2px;
  }
  .community-link:hover {
    background: var(--ind-accent) !important;
    color: #fff !important;
  }
  .community-link:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  .cta-link:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr !important;
    }
    section > div > div:first-child {
      flex-direction: column;
      align-items: flex-start;
    }
    section > div > div:first-child > div:last-child {
      text-align: left !important;
    }
  }
  @media (max-width: 640px) {
    section > div {
      padding: 0 24px !important;
    }
    .about-grid > div:last-child {
      grid-template-columns: 1fr !important;
    }
  }
</style>
