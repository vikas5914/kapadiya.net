---
import { socialLinks } from "../config";

const socials = [
  { label: "GitHub", value: "@vikas5914", href: socialLinks.github },
  { label: "LinkedIn", value: "vikaskapadiya", href: socialLinks.linkedin },
  { label: "Twitter / X", value: "@kapadiyavikas", href: socialLinks.twitter },
  { label: "Bluesky", value: "kapadiya.net", href: socialLinks.bluesky },
  { label: "Instagram", value: "@kapadiyavikas", href: socialLinks.instagram },
  { label: "Email", value: "vikas@kapadiya.net", href: socialLinks.email },
];
---

<section id="about" class="py-18 border-t border-border-medium">
  <div class="mx-auto max-w-[1440px] px-6 sm:px-12">
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-4 mb-12 pb-6 border-b border-border-soft">
      <div>
        <div class="text-[11px] font-medium tracking-[0.12em] uppercase text-ind-accent mb-3">
          Background
        </div>
        <h2 class="text-[40px] font-bold tracking-[-0.04em] uppercase text-text-primary leading-[0.95]">
          About Me
        </h2>
      </div>
      <div class="hidden md:block text-[13px] text-text-muted tracking-[-0.02em] max-w-[380px] leading-[1.6] text-right">
        Passionate full-stack developer with over 8 years of experience crafting digital solutions.
      </div>
    </div>

    <!-- Two Column Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Left Column — About Text -->
      <div class="flex flex-col gap-6">
        <p class="text-[14px] leading-[1.7] tracking-[-0.02em] [word-spacing:-0.08em] text-text-secondary">
          I'm a passionate full-stack developer with over 8 years of experience crafting
          digital solutions. My journey started with PHP, and I've been riding the Laravel
          wave since version 5.
        </p>
        <p class="text-[14px] leading-[1.7] tracking-[-0.02em] [word-spacing:-0.08em] text-text-secondary">
          When I'm not debugging code or exploring new frameworks, you'll find me contributing
          to open-source projects or helping fellow developers on Laravel Artisan community.
          I believe in writing clean, maintainable code and sharing knowledge with the
          developer community.
        </p>
        <p class="text-[14px] leading-[1.7] tracking-[-0.02em] [word-spacing:-0.08em] text-text-secondary">
          Currently, I'm exploring the intersection of AI and web development, experimenting
          with tools that can enhance developer productivity while maintaining code quality.
        </p>

        <!-- CTA Block -->
        <div class="bg-surface p-7 mt-2 shadow-[0_4px_12px_rgba(0,0,0,0.08)]">
          <div class="text-[12px] font-medium tracking-[0.06em] uppercase text-ind-accent mb-2">
            Available for freelance work
          </div>
          <div class="text-[13px] leading-[1.65] tracking-[-0.02em] text-text-secondary mb-5">
            Let's build something amazing together!
          </div>
          <a
            href="mailto:vikas@kapadiya.net"
            class="inline-flex items-center gap-2 no-underline text-[12px] font-semibold tracking-[0.1em] uppercase bg-ind-accent text-text-on-accent border-none px-6 py-3 transition-opacity duration-[240ms] hover:opacity-90 focus-visible:outline-2 focus-visible:outline-white focus-visible:outline-offset-2"
          >
            Get in touch →
          </a>
        </div>
      </div>

      <!-- Right Column — Social Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 border border-border-strong">
        {socials.map((s, i) => {
          const isRight = i % 2 === 1;
          const isLastRow = i >= socials.length - 2;
          return (
            <a
              href={s.href}
              target={s.href.startsWith("mailto") ? undefined : "_blank"}
              rel="noopener noreferrer"
              class:list={[
                "block no-underline p-5 transition-colors duration-[240ms]",
                "hover:bg-surface focus-visible:outline-2 focus-visible:outline-ind-accent focus-visible:-outline-offset-2",
                !isRight && "sm:border-r border-border-strong",
                !isLastRow && "border-b border-border-strong",
              ]}
            >
              <div class="text-[10px] font-medium tracking-[0.12em] uppercase text-text-muted mb-2">
                {s.label}
              </div>
              <div class="text-[14px] font-semibold tracking-[-0.02em] text-text-primary">
                {s.value}
              </div>
              <div class="text-[14px] text-ind-accent mt-2">
                →
              </div>
            </a>
          );
        })}

        <!-- Community Block -->
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 col-span-full p-6 border-t border-border-strong">
          <div>
            <div class="text-[10px] font-medium tracking-[0.12em] uppercase text-text-muted mb-1.5">
              Community
            </div>
            <div class="text-[16px] font-bold tracking-[-0.04em] uppercase text-text-primary">
              Laravel Artisan
            </div>
          </div>
          <a
            href="https://telegram.me/LaravelArtisans"
            target="_blank"
            rel="noopener noreferrer"
            class="no-underline text-[11px] font-medium tracking-[0.1em] uppercase text-ind-accent border border-ind-accent px-5 py-2.5 bg-transparent transition-colors duration-[240ms] hover:bg-ind-accent hover:text-text-on-accent focus-visible:outline-2 focus-visible:outline-white focus-visible:outline-offset-2 shrink-0"
          >
            Join →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
