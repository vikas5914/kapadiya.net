---
import { Image } from "astro:assets";
import profile from "@images/profile-v2.png";
import { socialLinks } from "../config";
import DotGrid from "./DotGrid.astro";

const proof = [
  "700+ GitHub stars",
  "90+ public repos",
  "10+ years shipping",
];
---

<section id="home" class="relative overflow-hidden border-b border-border-medium">
  <DotGrid />
  <div
    class="pointer-events-none absolute inset-0 bg-linear-to-r from-bg-main via-bg-main/92 to-bg-main/55"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-[1440px] px-6 sm:px-12">
    <div class="ledger-grid grid min-h-[calc(100svh-4rem)] border-x border-border-strong">
      <div class="flex flex-col px-6 py-16 sm:px-10 sm:py-20 lg:min-h-[720px] lg:px-14 lg:py-18">
        <div class="flex items-center justify-between border-b border-border-medium pb-4 font-mono text-xs font-medium tracking-[0.12em] uppercase">
          <span class="text-ind-accent">AI engineer / builder</span>
          <span class="hidden text-text-muted sm:block">Gandhinagar · India</span>
        </div>

        <div class="my-auto py-14 sm:py-18">
          <h1 class="hero-title max-w-[900px] font-bold uppercase text-text-primary">
            AI engineer<br />
            <span class="text-ind-accent">who ships.</span>
          </h1>
          <p class="mt-8 max-w-[620px] text-base leading-relaxed text-text-secondary sm:text-lg">
            I build agent systems and the TypeScript and Python services that
            keep them useful after the demo. Currently shipping at
            <span class="font-semibold text-text-primary">Shopos AI</span>.
          </p>

          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href={socialLinks.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex min-h-12 items-center justify-between bg-ind-accent px-6 text-xs font-mono font-semibold tracking-[0.12em] text-text-on-accent uppercase no-underline transition-colors duration-[240ms] hover:bg-ind-accent-hover focus-visible:outline-2 focus-visible:outline-ind-accent focus-visible:outline-offset-2 sm:min-w-[220px]"
            >
              Browse the work <span aria-hidden="true">↗</span>
            </a>
            <a
              href="#projects"
              class="inline-flex min-h-12 items-center justify-between border border-border-strong px-6 text-xs font-mono font-semibold tracking-[0.12em] text-text-primary uppercase no-underline transition-colors duration-[240ms] hover:border-ind-accent hover:text-ind-accent focus-visible:outline-2 focus-visible:outline-ind-accent focus-visible:outline-offset-2 sm:min-w-[190px]"
            >
              Selected projects <span aria-hidden="true">↓</span>
            </a>
          </div>
        </div>

        <div class="border-t border-border-medium pt-5">
          <div class="mb-3 font-mono text-xs font-medium tracking-[0.12em] text-text-muted uppercase">
            Public record
          </div>
          <div class="flex flex-wrap gap-x-3 gap-y-2 text-sm font-semibold text-text-primary">
            {proof.map((item, index) => (
              <>
                {index > 0 && <span class="text-ind-accent" aria-hidden="true">/</span>}
                <span>{item}</span>
              </>
            ))}
          </div>
        </div>
      </div>

      <aside class="flex flex-col border-t border-border-strong bg-surface lg:border-t-0 lg:border-l">
        <figure class="relative aspect-[4/3] overflow-hidden border-b border-border-strong lg:aspect-auto lg:min-h-[430px] lg:flex-1">
          <Image
            src={profile}
            alt="Vikas Kapadiya smiling against a dark background"
            class="h-full w-full object-cover object-[center_18%] saturate-[0.78] contrast-[1.06] transition-[filter,transform] duration-700 ease-out hover:scale-[1.015] hover:saturate-100 motion-reduce:transition-none motion-reduce:hover:scale-100 lg:object-[center_38%]"
            width={520}
            height={640}
            loading="eager"
            fetchpriority="high"
          />
          <div class="absolute inset-x-0 bottom-0 flex items-center justify-between bg-bg-main/90 px-5 py-4 font-mono text-xs tracking-[0.12em] uppercase">
            <span class="text-text-secondary">Portrait / 2026</span>
            <span class="text-ind-accent">VK</span>
          </div>
        </figure>

        <div class="p-6 sm:p-8">
          <div class="mb-5 flex items-center gap-3 font-mono text-xs font-medium tracking-[0.12em] uppercase text-success">
            <span class="size-2 rounded-full bg-success" aria-hidden="true"></span>
            Currently building
          </div>
          <p class="max-w-[34ch] text-xl font-semibold leading-snug tracking-tight text-text-primary">
            Agent workflows, LLM tooling, and the infrastructure underneath.
          </p>
          <div class="mt-7 flex items-center justify-between border-t border-border-soft pt-4 font-mono text-xs tracking-[0.12em] uppercase">
            <span class="text-text-muted">Shopos AI</span>
            <a
              href="mailto:vikas@kapadiya.net"
              class="-my-3 inline-flex min-h-11 items-center text-ind-accent no-underline transition-colors duration-[240ms] hover:text-ind-accent-hover focus-visible:outline-2 focus-visible:outline-ind-accent focus-visible:outline-offset-2"
            >
              Email ↗
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>
