---
import { Image } from "astro:assets";
import profile from "@images/profile.jpg";
---

<section id="home" class="relative" style="padding-top: 128px; padding-bottom: 72px;">
  <div class="mx-auto" style="max-width: var(--container-max); padding: 0 48px;">
    <!-- Top Label -->
    <div
      class="flex items-center gap-3"
      style="font-family: 'MonoLisa', monospace; font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ind-accent); margin-bottom: 24px;"
    >
      <div style="width: 32px; height: 1px; background: var(--ind-accent);"></div>
      Portfolio&nbsp;—&nbsp;2026
    </div>

    <!-- Main Layout -->
    <div class="grid gap-12 items-start" style="grid-template-columns: 1fr 400px;">
      <!-- Left Content -->
      <div>
        <h1
          style="font-family: 'MonoLisa', monospace; font-size: clamp(48px, 5.5vw, 80px); font-weight: 700; line-height: 0.95; letter-spacing: -0.04em; word-spacing: -0.15em; text-transform: uppercase; color: var(--text-primary); margin-bottom: 32px;"
        >
          I work with
          <span class="block" style="color: var(--ind-accent);">Noobs.</span>
        </h1>

        <p
          style="font-family: 'MonoLisa', monospace; font-size: 14px; line-height: 1.7; letter-spacing: -0.02em; word-spacing: -0.08em; color: var(--text-secondary); max-width: 560px; margin-bottom: 48px;"
        >
          Hey, I'm Vikas Kapadiya, your go-to full-stack developer who loves
          PHP almost as much as I love coffee (almost!). In my world, function
          declarations rule, and PHP 8's latest features are my playground.
        </p>

        <!-- Role Tags -->
        <div class="flex" style="border: 1px solid var(--border-strong); flex-wrap: wrap;">
          {["Full-Stack Developer", "Coffee Enthusiast", "Tech Explorer"].map((tag, i, arr) => (
            <div
              class="flex items-center gap-2.5"
              style={`padding: 14px 20px; font-family: 'MonoLisa', monospace; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-primary); font-weight: 500;${i < arr.length - 1 ? ' border-right: 1px solid var(--border-strong);' : ''}`}
            >
              <div style="width: 8px; height: 8px; background: var(--ind-accent); flex-shrink: 0;"></div>
              {tag}
            </div>
          ))}
        </div>
      </div>

      <!-- Right Content — Profile Card -->
      <div style="background: var(--surface); box-shadow: var(--shadow-industrial); overflow: hidden;">
        <!-- Profile Image -->
        <div
          class="relative flex items-center justify-center overflow-hidden"
          style="width: 100%; height: 360px; background: var(--ind-accent);"
        >
          <Image
            src={profile}
            alt="Vikas Kapadiya"
            class="w-full h-full object-cover"
            width={400}
            height={360}
            loading="eager"
          />
          <!-- Overlay -->
          <div
            class="absolute bottom-0 left-0 right-0 flex justify-between items-center"
            style="padding: 16px 20px; background: rgba(0,0,0,0.6);"
          >
            <span style="font-family: 'MonoLisa', monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.7);">
              Status
            </span>
            <span style="font-family: 'MonoLisa', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: #fff; font-weight: 600;">
              Available
            </span>
          </div>
        </div>

        <!-- Profile Info -->
        <div style="padding: 24px;">
          <div style="font-family: 'MonoLisa', monospace; font-size: 18px; font-weight: 700; letter-spacing: -0.04em; text-transform: uppercase; color: var(--text-primary); margin-bottom: 8px;">
            Vikas Kapadiya
          </div>
          <div style="font-family: 'MonoLisa', monospace; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ind-accent); margin-bottom: 16px;">
            Full-Stack Developer
          </div>
          <div style="font-family: 'MonoLisa', monospace; font-size: 13px; line-height: 1.65; letter-spacing: -0.02em; color: var(--text-muted);">
            By day, I juggle Laravel, Node.js, MySQL, and Tailwind to create web magic,
            and by night… well, I'm probably debugging.
          </div>
        </div>

        <!-- Status Row -->
        <div
          class="flex justify-between items-center"
          style="border-top: 1px solid var(--border-soft); padding: 14px 24px;"
        >
          <span style="font-family: 'MonoLisa', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-success-raw); font-weight: 500; display: flex; align-items: center;">
            <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--color-success-raw); display: inline-block; margin-right: 8px;"></span>
            Available for freelance
          </span>
          <span style="font-family: 'MonoLisa', monospace; font-size: 11px; letter-spacing: -0.02em; color: var(--text-muted);">
            REV 2026.05
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    section > div > div:last-child {
      grid-template-columns: 1fr !important;
    }
    section > div > div:last-child > div:last-child {
      order: -1;
    }
    section > div > div:nth-child(3) {
      grid-template-columns: 1fr !important;
    }
    section > div > div:nth-child(3) > div:last-child > div:last-child {
      max-width: 100% !important;
    }
  }
  @media (max-width: 640px) {
    section {
      padding-top: 96px !important;
      padding-bottom: 48px !important;
    }
    section > div {
      padding: 0 24px !important;
    }
    h1 {
      font-size: 36px !important;
    }
    section > div > div:nth-child(3) > div:first-child > div:last-child {
      flex-direction: column;
    }
  }
</style>
