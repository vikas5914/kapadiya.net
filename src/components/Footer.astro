---
import { socialLinks } from "../config";
const YEAR = new Date().getFullYear();

const cols = [
  {
    title: "Navigate",
    links: [
      { name: "Home", href: "#home" },
      { name: "About", href: "#about" },
      { name: "Skills", href: "#skills" },
      { name: "Blog", href: "/blog" },
    ],
  },
  {
    title: "Connect",
    links: [
      { name: "GitHub", href: socialLinks.github },
      { name: "LinkedIn", href: socialLinks.linkedin },
      { name: "Twitter / X", href: socialLinks.twitter },
      { name: "Bluesky", href: socialLinks.bluesky },
    ],
  },
  {
    title: "Contact",
    links: [
      { name: "vikas@kapadiya.net", href: socialLinks.email },
      { name: "Instagram", href: socialLinks.instagram },
      { name: "Laravel Artisan", href: "https://telegram.me/LaravelArtisans" },
    ],
  },
];

const linkClass =
  "block no-underline text-[13px] text-text-secondary tracking-[-0.02em] py-1 transition-colors duration-[240ms] hover:text-ind-accent focus-visible:outline-2 focus-visible:outline-ind-accent focus-visible:outline-offset-2";

const bottomLinkClass =
  "text-[12px] text-text-muted tracking-[-0.02em] cursor-pointer bg-transparent border-none p-0 transition-colors duration-[240ms] hover:text-ind-accent focus-visible:outline-2 focus-visible:outline-ind-accent focus-visible:outline-offset-2";
---

<footer class="py-12 border-t border-border-medium">
  <div class="mx-auto max-w-[1440px] px-6 sm:px-12">
    <!-- Top Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-[2fr_1fr_1fr_1fr] gap-12 pb-12 border-b border-border-soft">
      <!-- Brand Column -->
      <div>
        <div class="flex items-center gap-2.5 text-[18px] font-bold tracking-[-0.04em] uppercase text-text-primary mb-4">
          <div class="flex items-center justify-center w-6 h-6 bg-ind-accent text-text-on-accent text-[11px] font-bold">
            VK
          </div>
          Vikas Kapadiya
        </div>
        <div class="text-[13px] leading-[1.65] tracking-[-0.02em] text-text-muted max-w-[320px]">
          Full-stack developer passionate about creating amazing web experiences.
          Clean code, reliable systems, scalable architecture.
        </div>
      </div>

      <!-- Link Columns -->
      {cols.map((col) => (
        <div>
          <div class="text-[11px] font-medium tracking-[0.12em] uppercase text-text-muted mb-4">
            {col.title}
          </div>
          {col.links.map((link) => (
            <a
              href={link.href}
              target={link.href.startsWith("#") || link.href.startsWith("mailto") ? undefined : "_blank"}
              rel="noopener noreferrer"
              class={linkClass}
            >
              {link.name}
            </a>
          ))}
        </div>
      ))}
    </div>

    <!-- Bottom Row -->
    <div class="flex justify-between items-center pt-6">
      <span class="text-[12px] text-text-muted tracking-[-0.02em]">
        © {YEAR} Vikas Kapadiya — All rights reserved
      </span>
      <div class="flex gap-6">
        <button type="button" class={bottomLinkClass}>Privacy</button>
        <button type="button" class={bottomLinkClass}>Built with care</button>
      </div>
    </div>
  </div>
</footer>
