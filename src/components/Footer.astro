---
import { socialLinks } from "../config";
const YEAR = new Date().getFullYear();

const cols = [
  {
    title: "Navigate",
    links: [
      { name: "Home", href: "/#home" },
      { name: "About", href: "/#about" },
      { name: "Skills", href: "/#skills" },
      { name: "Blog", href: "/blog/" },
    ],
  },
  {
    title: "Connect",
    links: [
      { name: "GitHub", href: socialLinks.github },
      { name: "LinkedIn", href: socialLinks.linkedin },
      { name: "Twitter / X", href: socialLinks.twitter },
      { name: "Bluesky", href: socialLinks.bluesky },
    ],
  },
  {
    title: "Contact",
    links: [
      { name: "vikas@kapadiya.net", href: socialLinks.email },
      { name: "Instagram", href: socialLinks.instagram },
      { name: "Laravel Artisan", href: "https://telegram.me/LaravelArtisans" },
    ],
  },
];

const linkClass =
  "block no-underline text-sm text-text-secondary py-1 transition-colors duration-[240ms] hover:text-ind-accent focus-visible:outline-2 focus-visible:outline-ind-accent focus-visible:outline-offset-2";

const bottomLinkClass =
  "text-xs text-text-muted cursor-pointer bg-transparent border-none p-0 transition-colors duration-[240ms] hover:text-ind-accent focus-visible:outline-2 focus-visible:outline-ind-accent focus-visible:outline-offset-2";
---

<footer class="py-12 border-t border-border-medium">
  <div class="mx-auto max-w-[1440px] px-6 sm:px-12">
    <!-- Top Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-[2fr_1fr_1fr_1fr] gap-12 pb-12 border-b border-border-soft">
      <!-- Brand Column -->
      <div>
        <div class="flex items-center gap-2.5 text-lg font-bold tracking-tight uppercase text-text-primary mb-4">
          <div class="flex items-center justify-center w-6 h-6 bg-ind-accent text-text-on-accent text-xs font-bold">
            VK
          </div>
          Vikas Kapadiya
        </div>
        <div class="text-sm leading-relaxed text-text-muted max-w-[320px]">
          Full-stack developer passionate about creating amazing web experiences.
          Clean code, reliable systems, scalable architecture.
        </div>
      </div>

      <!-- Link Columns -->
      {cols.map((col) => (
        <div>
          <div class="text-xs font-medium tracking-widest uppercase text-text-muted mb-4">
            {col.title}
          </div>
          {col.links.map((link) => (
            <a
              href={link.href}
              target={link.href.startsWith("#") || link.href.startsWith("mailto") ? undefined : "_blank"}
              rel="noopener noreferrer"
              class={linkClass}
            >
              {link.name}
            </a>
          ))}
        </div>
      ))}
    </div>

    <!-- Bottom Row -->
    <div class="pt-6 text-right">
      <span class="text-xs text-text-muted">
        © {YEAR} Vikas Kapadiya — All rights reserved
      </span>
    </div>
  </div>
</footer>
