---
import { getCollection } from "astro:content";
import { writingTopics } from "../config";

const allPosts = await getCollection("posts");
const dateFormatter = new Intl.DateTimeFormat("en-US", { dateStyle: "long" });

const recentPosts = allPosts
  .sort(
    (a, b) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  )
  .slice(0, 3)
  .map((post) => {
    const dateObj = new Date(post.data.date);
    return {
      ...post.data,
      formattedDate: dateFormatter.format(dateObj),
      isoDate: dateObj.toISOString().slice(0, 10),
    };
  });

const hasPosts = recentPosts.length > 0;
---

<section id="writing" class="py-18 border-t border-border-medium" data-reveal>
  <div class="mx-auto max-w-[1440px] px-6 sm:px-12">
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-4 mb-12 pb-6 border-b border-border-soft">
      <div>
        <div class="text-xs font-mono font-medium tracking-widest uppercase text-ind-accent mb-3">
          Writing
        </div>
        <h2 class="text-4xl font-bold tracking-tight uppercase text-text-primary leading-none">
          {hasPosts ? "Recent posts" : "Writing"}
        </h2>
      </div>
      {hasPosts ? (
        <a
          href="/blog/"
          class="no-underline text-xs font-mono font-medium tracking-widest uppercase text-ind-accent hover:text-ind-accent-hover transition-colors duration-[240ms]"
        >
          All posts →
        </a>
      ) : (
        <div class="text-sm text-text-muted max-w-[320px] leading-relaxed md:text-right">
          TypeScript, agents, and whatever I just finished debugging.
        </div>
      )}
    </div>

    {hasPosts ? (
      <div
        class:list={[
          "grid grid-cols-1 md:grid-cols-2 border-t border-l border-border-strong",
          recentPosts.length === 3 && "lg:grid-cols-3",
        ]}
      >
        {recentPosts.map((post) => (
          <a
            href={`/blog/${post.slug}/`}
            class="group flex min-h-[240px] flex-col no-underline p-6 sm:p-7 border-r border-b border-border-strong transition-colors duration-[240ms] hover:bg-surface focus-visible:outline-2 focus-visible:outline-ind-accent focus-visible:-outline-offset-2"
          >
            <div class="text-xs font-semibold tracking-widest uppercase text-ind-accent mb-4">
              {post.category}
            </div>
            <div class="text-lg font-semibold leading-snug text-text-primary mb-3">
              {post.title}
            </div>
            <div class="text-sm leading-relaxed text-text-muted">
              {post.excerpt}
            </div>
            <div class="flex items-center gap-2 mt-auto pt-7 text-xs text-text-secondary">
              <time datetime={post.isoDate}>{post.formattedDate}</time>
              <span aria-hidden="true">·</span>
              <span>{post.readTime}</span>
              <span class="ml-auto text-base text-ind-accent transition-transform duration-[240ms] group-hover:translate-x-1" aria-hidden="true">→</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-[1.2fr_1fr] border border-border-strong">
        <div class="p-7 sm:p-10 border-b md:border-b-0 md:border-r border-border-strong">
          <div class="text-xs font-mono font-medium tracking-widest uppercase text-ind-accent mb-4">
            Nothing here yet
          </div>
          <p class="text-base leading-relaxed text-text-secondary max-w-[480px] mb-6">
            When something bites me hard enough, I write it down.
            TypeScript messes, agent setups, open source notes. First
            posts soon.
          </p>
          <a
            href="mailto:vikas@kapadiya.net?subject=Writing%20topic%20idea"
            class="inline-flex items-center gap-2 no-underline text-xs font-semibold tracking-widest uppercase border border-border-strong text-text-primary px-6 py-3 transition-colors duration-[240ms] hover:border-ind-accent hover:text-ind-accent focus-visible:outline-2 focus-visible:outline-ind-accent focus-visible:outline-offset-2"
          >
            Suggest a topic
          </a>
        </div>
        <div class="p-7 sm:p-10">
          <div class="text-xs font-mono font-medium tracking-widest uppercase text-text-muted mb-4">
            On the list
          </div>
          <ul class="flex flex-col gap-0 list-none p-0 m-0">
            {writingTopics.map((topic, i) => (
              <li
                class:list={[
                  "py-3 text-sm text-text-secondary",
                  i < writingTopics.length - 1 && "border-b border-border-soft",
                ]}
              >
                <span class="text-ind-accent font-mono text-xs mr-2">//</span>
                {topic}
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}
  </div>
</section>
