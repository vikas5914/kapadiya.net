---
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");
const dateFormatter = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const recentPosts = allPosts
  .sort(
    (a, b) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  )
  .slice(0, 4)
  .map((post) => {
    const dateObj = new Date(post.data.date);
    return {
      ...post.data,
      formattedDate: dateFormatter.format(dateObj),
      isoDate: dateObj.toISOString().slice(0, 10),
    };
  });
---

<section id="writing" class="border-b border-border-medium">
  <div class="mx-auto max-w-[1440px] px-6 sm:px-12">
    <div class="border-x border-border-strong">
      <header class="ledger-grid grid border-b border-border-strong">
        <div class="px-6 py-14 sm:px-10 sm:py-18 lg:px-14">
          <h2 class="section-title font-bold uppercase text-text-primary">Field notes.</h2>
          <p class="mt-5 max-w-[58ch] text-base leading-relaxed text-text-secondary">
            Short write-ups from the workbench: agent setups, TypeScript edge cases,
            and fixes I would rather not rediscover.
          </p>
        </div>
        <div class="flex flex-col justify-between border-t border-border-strong p-6 sm:p-8 lg:border-t-0 lg:border-l">
          <span class="font-mono text-xs font-medium tracking-[0.12em] text-text-muted uppercase">
            Recent dispatches
          </span>
          <a
            href="/blog/"
            class="mt-10 flex min-h-11 items-center justify-between border-t border-border-medium pt-4 font-mono text-xs font-medium tracking-[0.12em] text-ind-accent uppercase no-underline transition-colors duration-[240ms] hover:text-ind-accent-hover focus-visible:outline-2 focus-visible:outline-ind-accent focus-visible:outline-offset-2"
          >
            Browse all notes <span aria-hidden="true">→</span>
          </a>
        </div>
      </header>

      <div>
        {recentPosts.map((post, index) => (
          <a
            href={`/blog/${post.slug}/`}
            class:list={[
              "group grid grid-cols-1 px-6 py-7 text-text-primary no-underline transition-colors duration-[240ms] hover:bg-surface focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-ind-accent sm:px-10 lg:grid-cols-[180px_minmax(0,1fr)_100px_36px] lg:items-center lg:px-14",
              index < recentPosts.length - 1 && "border-b border-border-strong",
            ]}
          >
            <div class="flex items-center gap-3 font-mono text-xs tracking-[0.08em] uppercase">
              <time datetime={post.isoDate} class="text-text-muted">{post.formattedDate}</time>
            </div>
            <div class="mt-3 lg:mt-0 lg:px-8">
              <div class="font-mono text-xs font-medium tracking-[0.1em] text-ind-accent uppercase">{post.category}</div>
              <h3 data-post-title class="mt-2 text-xl font-semibold leading-snug tracking-tight text-text-primary transition-colors duration-[240ms] group-hover:text-ind-accent">
                {post.title}
              </h3>
            </div>
            <span class="mt-4 font-mono text-xs tracking-[0.08em] text-text-muted uppercase lg:mt-0">{post.readTime}</span>
            <span class="mt-4 text-xl text-ind-accent transition-transform duration-[240ms] group-hover:translate-x-1 lg:mt-0 lg:text-right" aria-hidden="true">→</span>
          </a>
        ))}
      </div>

      <div class="flex flex-col gap-6 border-t border-border-strong bg-surface px-6 py-8 sm:flex-row sm:items-center sm:justify-between sm:px-10 lg:px-14">
        <p class="max-w-[52ch] text-sm leading-relaxed text-text-secondary">
          Prefer the raw feed? Every post is available as Markdown for people and agents.
        </p>
        <a
          href="/blog/index.md"
          class="inline-flex min-h-11 shrink-0 items-center font-mono text-xs font-medium tracking-[0.12em] text-ind-accent uppercase no-underline transition-colors duration-[240ms] hover:text-ind-accent-hover focus-visible:outline-2 focus-visible:outline-ind-accent focus-visible:outline-offset-2"
        >
          Read Markdown ↗
        </a>
      </div>
    </div>
  </div>
</section>
