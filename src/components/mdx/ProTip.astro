---
interface Props {
  title?: string;
}

const { title = "Pro tip" } = Astro.props;
---

<aside class="pro-tip mb-6 border border-border-strong bg-surface-elevated p-6">
  <div class="mb-4 flex items-center gap-3">
    <span class="flex size-6 shrink-0 items-center justify-center bg-ind-accent font-mono text-xs font-bold leading-none text-text-on-accent" aria-hidden="true">+</span>
    <h3 class="pro-tip__title m-0 text-base font-bold leading-snug text-text-primary">{title}</h3>
  </div>
  <div class="text-text-secondary">
    <slot />
  </div>
</aside>
