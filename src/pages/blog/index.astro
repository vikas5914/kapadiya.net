---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");

const dateFormatter = new Intl.DateTimeFormat("en-US", { dateStyle: "long" });

const blogPosts = allPosts
  .map((post: any) => {
    const dateObj = new Date(post.data.date);
    return {
      ...post.data,
      id: post.id,
      slug: post.data.slug || post.slug,
      formattedDate: dateFormatter.format(dateObj),
      isoDate: dateObj.toISOString().slice(0, 10),
    };
  })
  .sort(
    (a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime()
  );
---

<Base
  title="Blog - Vikas Kapadiya"
  description="Occasional posts on TypeScript, agents, and whatever I'm debugging."
>
  <section class="py-18 border-t border-border-medium">
    <div class="mx-auto max-w-[1440px] px-6 sm:px-12">
      <!-- Header -->
      <div class="mb-12 pb-6 border-b border-border-soft">
        <div class="text-xs font-medium tracking-widest uppercase text-ind-accent mb-3">
          Writing
        </div>
        <h1 class="text-4xl font-bold tracking-tight uppercase text-text-primary leading-none">
          Blog
        </h1>
        <p class="mt-4 text-sm text-text-muted max-w-[480px] leading-relaxed">
          Occasional posts. TypeScript, agents, open source — whatever
          was annoying enough to write down.
        </p>
      </div>

      {blogPosts.length > 0 ? (
        <div class="flex flex-col border border-border-strong">
          {blogPosts.map((post: any, i: number) => (
            <a
              href={`/blog/${post.slug}/`}
              class:list={[
                "block no-underline grid grid-cols-1 sm:grid-cols-[60px_1fr_auto] transition-colors duration-[240ms] hover:bg-surface",
                i < blogPosts.length - 1 && "border-b border-border-strong",
              ]}
            >
              <div class="hidden sm:flex items-center text-sm italic text-text-muted px-4 py-6 border-r border-border-strong">
                0{i + 1}
              </div>
              <div class="p-6">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-xs font-semibold tracking-widest uppercase text-text-on-accent bg-ind-accent px-2.5 py-1.5">
                    {post.category}
                  </span>
                  {post.featured && (
                    <span class="text-xs font-bold tracking-widest uppercase text-ind-accent bg-bg-main border border-ind-accent px-2 py-1">
                      Featured
                    </span>
                  )}
                </div>
                <div class="text-base font-semibold text-text-primary mb-1.5">
                  {post.title}
                </div>
                <div class="text-sm leading-relaxed text-text-muted max-w-[600px]">
                  {post.excerpt}
                </div>
              </div>
              <div class="flex sm:flex-col flex-row items-center sm:items-end sm:justify-center gap-2 px-6 py-3 sm:p-6 border-t sm:border-t-0 sm:border-l border-border-soft sm:border-border-strong">
                <time
                  datetime={post.isoDate}
                  class="text-xs text-text-secondary"
                >
                  {post.formattedDate}
                </time>
                <span class="text-xs text-text-secondary">
                  {post.readTime}
                </span>
                <span class="text-sm text-ind-accent">→</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-18">
          <div class="text-lg font-semibold text-text-primary mb-3">
            No posts yet
          </div>
          <div class="text-sm text-text-muted mb-6 max-w-[400px] mx-auto leading-relaxed">
            Nothing published. I'll put something here when the next
            debugging session is worth sharing.
          </div>
          <a
            href="/"
            class="inline-block no-underline text-xs font-semibold tracking-widest uppercase bg-ind-accent text-text-on-accent px-6 py-3"
          >
            ← Back to Home
          </a>
        </div>
      )}
    </div>
  </section>
</Base>
