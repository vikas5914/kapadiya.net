---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");

const blogPosts = allPosts
  .map((post: any) => ({
    ...post.data,
    id: post.id,
    slug: post.data.slug || post.slug,
  }))
  .sort(
    (a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime()
  );
---

<Base
  title="Blog - Vikas Kapadiya"
  description="Blog posts about full-stack development, Laravel, Node.js, and modern web technologies."
>
  <section style="padding: 72px 0; border-top: 1px solid var(--border-medium);">
    <div class="mx-auto" style="max-width: var(--container-max); padding: 0 48px;">
      <!-- Header -->
      <div style="margin-bottom: 48px; padding-bottom: 24px; border-bottom: 1px solid var(--border-soft);">
        <div
          style="font-family: 'MonoLisa', monospace; font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ind-accent); margin-bottom: 12px;"
        >
          Writing
        </div>
        <h1
          style="font-family: 'MonoLisa', monospace; font-size: 40px; font-weight: 700; letter-spacing: -0.04em; text-transform: uppercase; color: var(--text-primary); line-height: 0.95;"
        >
          Blog Posts
        </h1>
      </div>

      {blogPosts.length > 0 ? (
        <div class="flex flex-col" style="border: 1px solid var(--border-strong);">
          {blogPosts.map((post: any, i: number) => (
            <a
              href={`/blog/${post.slug}`}
              class="blog-post-link block no-underline"
              style={`display: grid; grid-template-columns: 60px 1fr auto; transition: background 240ms ease;${i < blogPosts.length - 1 ? ' border-bottom: 1px solid var(--border-strong);' : ''}`}
            >
              <div
                style="font-family: 'MonoLisa', monospace; font-size: 13px; font-style: italic; color: var(--text-muted); padding: 24px 16px; border-right: 1px solid var(--border-strong); display: flex; align-items: center;"
              >
                0{i + 1}
              </div>
              <div style="padding: 24px;">
                <div class="flex items-center gap-3" style="margin-bottom: 8px;">
                  <span
                    style="font-family: 'MonoLisa', monospace; font-size: 10px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ind-accent); background: var(--ind-accent-muted); padding: 4px 8px;"
                  >
                    {post.category}
                  </span>
                  {post.featured && (
                    <span
                      style="font-family: 'MonoLisa', monospace; font-size: 10px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); background: var(--surface-elevated); padding: 4px 8px;"
                    >
                      Featured
                    </span>
                  )}
                </div>
                <div
                  style="font-family: 'MonoLisa', monospace; font-size: 16px; font-weight: 600; letter-spacing: -0.02em; color: var(--text-primary); margin-bottom: 6px;"
                >
                  {post.title}
                </div>
                <div
                  style="font-family: 'MonoLisa', monospace; font-size: 13px; line-height: 1.6; color: var(--text-muted); max-width: 600px;"
                >
                  {post.excerpt}
                </div>
              </div>
              <div
                class="flex flex-col items-end justify-center gap-2"
                style="padding: 24px; border-left: 1px solid var(--border-strong);"
              >
                <span
                  style="font-family: 'MonoLisa', monospace; font-size: 11px; color: var(--text-muted); letter-spacing: -0.02em;"
                >
                  {new Date(post.date).toLocaleDateString()}
                </span>
                <span
                  style="font-family: 'MonoLisa', monospace; font-size: 11px; color: var(--text-muted); letter-spacing: -0.02em;"
                >
                  {post.readTime}
                </span>
                <span style="font-family: 'MonoLisa', monospace; font-size: 14px; color: var(--ind-accent);">→</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div style="text-align: center; padding: 72px 0;">
          <div
            style="font-family: 'MonoLisa', monospace; font-size: 18px; font-weight: 600; color: var(--text-primary); margin-bottom: 12px;"
          >
            No blog posts yet
          </div>
          <div
            style="font-family: 'MonoLisa', monospace; font-size: 13px; color: var(--text-muted); margin-bottom: 24px; max-width: 400px; margin-inline: auto; line-height: 1.6;"
          >
            I'm working on some exciting content! Check back soon for insights
            and tutorials.
          </div>
          <a
            href="/"
            class="inline-block no-underline"
            style="font-family: 'MonoLisa', monospace; font-size: 11px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; background: var(--ind-accent); color: #fff; padding: 12px 24px;"
          >
            ← Back to Home
          </a>
        </div>
      )}
    </div>
  </section>
</Base>

<style>
  .blog-post-link:hover {
    background: var(--surface) !important;
  }
  @media (max-width: 640px) {
    section > div {
      padding: 0 24px !important;
    }
    .blog-post-link {
      grid-template-columns: 1fr !important;
    }
    .blog-post-link > div:first-child {
      display: none !important;
    }
    .blog-post-link > div:last-child {
      border-left: none !important;
      flex-direction: row;
      padding: 12px 24px !important;
      border-top: 1px solid var(--border-soft);
    }
  }
</style>
