---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const blogPosts = allPosts
  .map((post) => {
    const dateObj = new Date(post.data.date);
    return {
      ...post.data,
      id: post.id,
      slug: post.data.slug,
      formattedDate: dateFormatter.format(dateObj),
      isoDate: dateObj.toISOString().slice(0, 10),
    };
  })
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const [leadPost, ...archivePosts] = blogPosts;
---

<Base
  title="Field Notes"
  description="Field notes on TypeScript, agents, open source, and whatever I just finished debugging."
>
  <section class="border-b border-border-medium">
    <div class="mx-auto max-w-[1440px] px-6 sm:px-12">
      <div class="border-x border-border-strong">
        <header class="ledger-grid grid border-b border-border-strong">
          <div class="px-6 py-14 sm:px-10 sm:py-18 lg:px-14 lg:py-20">
            <p class="font-mono text-xs font-medium tracking-[0.12em] text-ind-accent uppercase">
              Notes from the workbench
            </p>
            <h1 class="section-title mt-6 font-bold text-text-primary uppercase">
              Field notes.
            </h1>
            <p class="mt-6 max-w-[58ch] text-base leading-relaxed text-text-secondary">
              TypeScript edge cases, agent setups, open-source lessons, and fixes
              I would rather not rediscover.
            </p>
          </div>

          <div class="flex flex-col justify-between border-t border-border-strong bg-surface p-6 sm:p-8 lg:border-t-0 lg:border-l">
            <div class="flex items-center justify-between font-mono text-xs tracking-[0.12em] text-text-muted uppercase">
              <span>Archive</span>
              <span aria-label={`${blogPosts.length} published posts`}>{String(blogPosts.length).padStart(2, "0")}</span>
            </div>
            <div class="mt-14">
              <div class="text-2xl font-semibold tracking-tight text-text-primary">
                {blogPosts.length} published
              </div>
              <div class="mt-2 text-sm text-text-muted">
                Source-friendly Markdown for every note.
              </div>
            </div>
            <a
              href="/blog/index.md"
              class="mt-8 flex min-h-11 items-center justify-between border-t border-border-medium pt-4 font-mono text-xs font-medium tracking-[0.12em] text-ind-accent uppercase no-underline transition-colors duration-[240ms] hover:text-ind-accent-hover focus-visible:outline-2 focus-visible:outline-ind-accent focus-visible:outline-offset-2"
            >
              Markdown index <span aria-hidden="true">↗</span>
            </a>
          </div>
        </header>

        {leadPost && (
          <a
            href={`/blog/${leadPost.slug}/`}
            class="ledger-grid group grid border-b border-border-strong text-text-primary no-underline focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-ind-accent"
          >
            <div class="px-6 py-12 transition-colors duration-[240ms] group-hover:bg-surface sm:px-10 sm:py-14 lg:px-14 lg:py-16">
              <div class="flex flex-wrap items-center gap-3 font-mono text-xs font-medium tracking-[0.1em] text-ind-accent uppercase">
                <span>Latest dispatch</span>
                {leadPost.featured && (
                  <span class="border border-ind-accent px-2 py-1">Featured</span>
                )}
              </div>
              <h2
                data-post-title
                class="mt-7 max-w-[820px] text-[clamp(2rem,5vw,4.5rem)] font-bold leading-[0.98] tracking-[-0.035em] text-text-primary transition-colors duration-[240ms] group-hover:text-ind-accent"
              >
                {leadPost.title}
              </h2>
              <p class="mt-7 max-w-[65ch] text-base leading-relaxed text-text-secondary">
                {leadPost.excerpt}
              </p>
            </div>

            <div class="flex flex-col justify-between border-t border-border-strong bg-surface p-6 transition-colors duration-[240ms] group-hover:bg-surface-elevated sm:p-8 lg:border-t-0 lg:border-l">
              <div class="grid grid-cols-2 gap-x-6 gap-y-8">
                <div>
                  <div class="font-mono text-[0.6875rem] tracking-[0.1em] text-text-muted uppercase">Published</div>
                  <time datetime={leadPost.isoDate} class="mt-2 block text-sm text-text-primary">
                    {leadPost.formattedDate}
                  </time>
                </div>
                <div>
                  <div class="font-mono text-[0.6875rem] tracking-[0.1em] text-text-muted uppercase">Read time</div>
                  <div class="mt-2 text-sm text-text-primary">{leadPost.readTime}</div>
                </div>
                <div class="col-span-2">
                  <div class="font-mono text-[0.6875rem] tracking-[0.1em] text-text-muted uppercase">Filed under</div>
                  <div class="mt-2 text-sm text-text-primary">{leadPost.category}</div>
                </div>
              </div>
              <div class="mt-12 flex min-h-11 items-center justify-between border-t border-border-medium pt-4 font-mono text-xs font-medium tracking-[0.12em] text-ind-accent uppercase">
                Read dispatch
                <span class="text-xl transition-transform duration-[240ms] group-hover:translate-x-1" aria-hidden="true">→</span>
              </div>
            </div>
          </a>
        )}

        {archivePosts.length > 0 && (
          <section aria-labelledby="archive-heading">
            <div class="ledger-grid grid border-b border-border-strong">
              <div class="px-6 py-7 sm:px-10 lg:px-14">
                <h2 id="archive-heading" class="font-mono text-xs font-medium tracking-[0.12em] text-text-primary uppercase">
                  Archive
                </h2>
              </div>
              <div class="border-t border-border-strong bg-surface px-6 py-7 font-mono text-xs tracking-[0.12em] text-text-muted uppercase sm:px-8 lg:border-t-0 lg:border-l">
                {archivePosts.length} earlier {archivePosts.length === 1 ? "note" : "notes"}
              </div>
            </div>

            <div>
              {archivePosts.map((post, index) => (
                <a
                  href={`/blog/${post.slug}/`}
                  class:list={[
                    "group grid grid-cols-[56px_minmax(0,1fr)] text-text-primary no-underline transition-colors duration-[240ms] hover:bg-surface focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-ind-accent sm:grid-cols-[72px_minmax(0,1fr)] lg:grid-cols-[88px_170px_minmax(0,1fr)_150px_44px] lg:items-center",
                    index < archivePosts.length - 1 && "border-b border-border-strong",
                  ]}
                >
                  <div class="flex h-full items-start justify-center border-r border-border-medium px-3 py-8 font-mono text-xs tracking-[0.08em] text-text-muted sm:py-9 lg:items-center">
                    {String(index + 2).padStart(2, "0")}
                  </div>
                  <time datetime={post.isoDate} class="hidden px-6 font-mono text-xs tracking-[0.08em] text-text-muted uppercase lg:block">
                    {post.formattedDate}
                  </time>
                  <div class="px-6 py-8 sm:px-8 sm:py-9 lg:px-0">
                    <div class="flex flex-wrap items-center gap-3 font-mono text-[0.6875rem] font-medium tracking-[0.1em] text-ind-accent uppercase">
                      <span>{post.category}</span>
                      {post.featured && <span class="border border-ind-accent px-2 py-1">Featured</span>}
                    </div>
                    <h3 data-post-title class="mt-2 text-xl font-semibold leading-snug tracking-tight text-text-primary transition-colors duration-[240ms] group-hover:text-ind-accent">
                      {post.title}
                    </h3>
                    <p class="mt-2 max-w-[65ch] text-sm leading-relaxed text-text-muted">{post.excerpt}</p>
                    <div class="mt-4 flex items-center gap-4 font-mono text-[0.6875rem] tracking-[0.08em] text-text-muted uppercase lg:hidden">
                      <time datetime={post.isoDate}>{post.formattedDate}</time>
                      <span aria-hidden="true">/</span>
                      <span>{post.readTime}</span>
                    </div>
                  </div>
                  <span class="hidden font-mono text-xs tracking-[0.08em] text-text-muted uppercase lg:block">{post.readTime}</span>
                  <span class="hidden pr-6 text-right text-xl text-ind-accent transition-transform duration-[240ms] group-hover:translate-x-1 lg:block" aria-hidden="true">→</span>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>
    </div>
  </section>
</Base>
