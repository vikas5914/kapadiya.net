---
import Base from "../layouts/Base.astro";
---

<Base title="Not Found" description="The requested page does not exist.">
  <section class="border-b border-border-medium">
    <div class="mx-auto max-w-[1440px] px-6 sm:px-12">
      <div class="ledger-grid grid min-h-[70svh] border-x border-border-strong">
        <div class="flex flex-col justify-center px-6 py-16 sm:px-10 lg:px-14">
          <div class="mb-6 font-mono text-xs font-medium tracking-[0.12em] text-ind-accent uppercase">
            Error / 404
          </div>
          <h1 class="section-title max-w-[12ch] font-bold uppercase text-text-primary">
            Nothing shipped here.
          </h1>
          <p class="mt-6 max-w-[48ch] text-base leading-relaxed text-text-secondary">
            The route may have moved, or it never existed in the first place.
          </p>
          <a
            href="/"
            class="mt-8 inline-flex min-h-12 max-w-48 items-center justify-between bg-ind-accent px-5 font-mono text-xs font-semibold tracking-[0.12em] text-text-on-accent uppercase no-underline transition-colors duration-[240ms] hover:bg-ind-accent-hover focus-visible:outline-2 focus-visible:outline-ind-accent focus-visible:outline-offset-2"
          >
            Back home <span aria-hidden="true">←</span>
          </a>
        </div>
        <div class="flex items-center justify-center border-t border-border-strong bg-surface p-8 lg:border-t-0 lg:border-l">
          <span class="font-mono text-[clamp(7rem,24vw,15rem)] font-bold leading-none tracking-[-0.04em] text-border-strong" aria-hidden="true">404</span>
        </div>
      </div>
    </div>
  </section>
</Base>
